{
    "family": "lifesync-admin-td",
    "executionRoleArn": "arn:aws:iam::354493396671:role/lifesync-dev-21-lifesync-ecs-exist-EcsExecutionRole-ZE9R5wfJvb9o",
    "taskRoleArn": "arn:aws:iam::354493396671:role/lifesync-dev-21-lifesync-ecs-existing-v-EcsTaskRole-jy5xSj383Tcz",
    "networkMode": "awsvpc",
    "cpu": "256",
    "memory": "512",
    "requiresCompatibilities": ["EC2"],
    "containerDefinitions": [
        {
            "name": "admin",
            "image": "354493396671.dkr.ecr.ap-northeast-2.amazonaws.com/lifesync-dev-admin-service:latest",
            "cpu": 0,
            "portMappings": [{"containerPort": 80, "hostPort": 80, "protocol": "tcp"}],
            "essential": true,
            "environment": [
                {"name": "USE_MOCK", "value": "true"}
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/lifesync-admin",
                    "awslogs-region": "ap-northeast-2",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ]
}
