{
    "family": "lifesync-dev-21-lifesync-ecs-existing-vpc-v4-td",
    "executionRoleArn": "arn:aws:iam::354493396671:role/lifesync-dev-21-lifesync-ecs-exist-EcsExecutionRole-ZE9R5wfJvb9o",
    "taskRoleArn": "arn:aws:iam::354493396671:role/lifesync-dev-21-lifesync-ecs-existing-v-EcsTaskRole-jy5xSj383Tcz",
    "networkMode": "awsvpc",
    "cpu": "512",
    "memory": "1024",
    "requiresCompatibilities": ["EC2"],
    "containerDefinitions": [
        {
            "name": "app",
            "image": "354493396671.dkr.ecr.ap-northeast-2.amazonaws.com/lifesync-dev-lifesync360-service:5dca525e",
            "cpu": 0,
            "portMappings": [{"containerPort": 80, "hostPort": 80, "protocol": "tcp"}],
            "essential": true,
            "environment": [{"name": "USE_MOCK", "value": "true"}],
            "secrets": [{"name": "JWT_SECRET", "valueFrom": "arn:aws:ssm:ap-northeast-2:354493396671:parameter/lifesync360/jwt-secret"}],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/lifesync-platform",
                    "awslogs-region": "ap-northeast-2",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ]
}
