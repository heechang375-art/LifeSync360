#!/bin/bash


###############################################################################
# DATABASE CHARSET
###############################################################################

export DB_CHARSET="utf8mb4"

###############################################################################
# DATABASE PORT
###############################################################################

export DB_PORT="3306"

###############################################################################
# EXECUTION MODE
###############################################################################

export EXECUTION_MODE="PROD"

###############################################################################
# LOG LEVEL
###############################################################################

export LOG_LEVEL="INFO"

###############################################################################
# PROJECT HOME
###############################################################################

export PROJECT_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

###############################################################################
# LOG DIRECTORY
###############################################################################

export LOG_DIR="${PROJECT_HOME}/logs"

###############################################################################
# SQL DIRECTORY
###############################################################################

export SQL_DIR="${PROJECT_HOME}"

###############################################################################
# SIMULATION CONFIG
###############################################################################

export RECOMMEND_TARGET_CUSTOMER="100000"

export RECOMMEND_HISTORY_COUNT="1000000"

export DASHBOARD_LOG_COUNT="1500000"

###############################################################################
# TIMEZONE
###############################################################################

export TZ="Asia/Seoul"