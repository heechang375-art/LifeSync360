# ── 공통 ──────────────────────────────────────────────
USE_MOCK=true
JWT_SECRET=

# ── 클라우드 전환 시 (USE_MOCK=false) ────────────────

# Service-DB Aurora (lifesync360)
AURORA_HOST=
DB_USER=
DB_PASS=
DB_NAME=lifesync360

# 인증 DB — users / consent (온프레미스 또는 별도 Aurora)
AUTH_DB_HOST=
AUTH_DB_USER=
AUTH_DB_PASS=
AUTH_DB_NAME=

# DynamoDB
DYNAMO_TABLE=
AWS_REGION=ap-northeast-2

# ElastiCache Redis
REDIS_HOST=
REDIS_PORT=6379

# Lambda (선택 — global_id 매핑용)
PROFILE_SYNC_LAMBDA=
