# 로컬 실행 시 이 파일을 .env.local로 복사 후 값을 채워서 사용
# cp .env.example .env.local

# ── 공통 ──────────────────────────────────────────────
USE_MOCK=true
JWT_SECRET=<32바이트-이상-랜덤-문자열>

# ── 클라우드 전환 시 (USE_MOCK=false) ────────────────
# USE_MOCK=false
# JWT_SECRET=<Secrets Manager에서 주입>

# Aurora (ECS taskdef.json secrets 또는 로컬 직접 설정)
# AURORA_HOST=<aurora-cluster-endpoint>
# DB_USER=<aurora-username>
# DB_PASS=<aurora-password>
# DB_NAME=lifesync

# DynamoDB
# DYNAMO_TABLE=lifesync-scores
# AWS_REGION=ap-northeast-2

# ElastiCache Redis
# REDIS_HOST=<elasticache-endpoint>
# REDIS_PORT=6379
