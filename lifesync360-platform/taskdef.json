{
  "family": "lifesync-platform",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::354493396671:role/lifesync-EcsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::354493396671:role/lifesync-EcsPlatformTaskRole",
  "containerDefinitions": [
    {
      "name": "platform",
      "image": "<IMAGE1_NAME>",
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "AWS_REGION",    "value": "ap-northeast-2" },
        { "name": "DB_NAME",       "value": "lifesync" },
        { "name": "DYNAMO_TABLE",  "value": "lifesync-scores" },
        { "name": "REDIS_PORT",    "value": "6379" },
        { "name": "USE_MOCK",              "value": "false" },
        { "name": "PROFILE_SYNC_LAMBDA",  "value": "customer-profile-sync" },
        { "name": "ONPREM_QUERY_LAMBDA",  "value": "lifesync-onprem-customer-query" }
      ],
      "secrets": [
        {
          "name": "AURORA_HOST",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:354493396671:secret:lifesync/aurora:host::"
        },
        {
          "name": "DB_USER",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:354493396671:secret:lifesync/aurora:user::"
        },
        {
          "name": "DB_PASS",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:354493396671:secret:lifesync/aurora:password::"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:354493396671:secret:lifesync/jwt:secret::"
        },
        {
          "name": "REDIS_HOST",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:354493396671:secret:lifesync/redis:host::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/lifesync-platform",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
