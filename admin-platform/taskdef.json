{
  "family": "lifesync-admin",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/lifesync-EcsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/lifesync-EcsAdminTaskRole",
  "containerDefinitions": [
    {
      "name": "admin",
      "image": "<IMAGE1_NAME>",
      "portMappings": [
        {
          "containerPort": 5001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "AWS_REGION",   "value": "ap-northeast-2" },
        { "name": "DB_NAME",      "value": "lifesync" },
        { "name": "DYNAMO_TABLE", "value": "lifesync-scores" },
        { "name": "USE_MOCK",     "value": "false" }
      ],
      "secrets": [
        {
          "name": "AURORA_HOST",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:lifesync/aurora:host::"
        },
        {
          "name": "DB_USER",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:lifesync/aurora:user::"
        },
        {
          "name": "DB_PASS",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:lifesync/aurora:password::"
        },
        {
          "name": "SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:lifesync/admin:secret_key::"
        },
        {
          "name": "ADMIN_USER",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:lifesync/admin:username::"
        },
        {
          "name": "ADMIN_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:ACCOUNT_ID:secret:lifesync/admin:password::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/lifesync-admin",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
