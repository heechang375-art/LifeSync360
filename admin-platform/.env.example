# 로컬 실행 시 이 파일을 .env.local로 복사 후 값을 채워서 사용
# cp .env.example .env.local

# ── 공통 ──────────────────────────────────────────────
USE_MOCK=true
SECRET_KEY=<32바이트-이상-랜덤-문자열>
ADMIN_USER=admin
ADMIN_PASSWORD=<어드민-비밀번호>

# ── 클라우드 전환 시 (USE_MOCK=false) ────────────────
# USE_MOCK=false
# SECRET_KEY=<Secrets Manager에서 주입>
# ADMIN_USER=<Secrets Manager에서 주입>
# ADMIN_PASSWORD=<Secrets Manager에서 주입>

# Aurora
# AURORA_HOST=<aurora-cluster-endpoint>
# DB_USER=<aurora-username>
# DB_PASS=<aurora-password>
# DB_NAME=lifesync

# DynamoDB
# DYNAMO_TABLE=lifesync-scores
# AWS_REGION=ap-northeast-2
