[Unit]
Description=LifeSync360 Private API
After=network.target

[Service]
Type=simple
User=ansible
WorkingDirectory=/opt/private-api
ExecStart=/usr/local/bin/uvicorn app:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5
Environment=ENV=production
Environment=AWS_DEFAULT_REGION=ap-northeast-2

[Install]
WantedBy=multi-user.target
